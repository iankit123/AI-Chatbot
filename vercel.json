{
  "version": 2,
  "routes": [
    {
      "src": "/api/ping",
      "dest": "/api/ping"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
